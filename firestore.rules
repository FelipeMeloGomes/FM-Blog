rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userPreferences/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.colorMode is string
                   && request.resource.data.colorMode in ['light', 'dark'];
      allow update: if request.auth != null && request.auth.uid == userId
                   && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['colorMode']);
      allow delete: if false;
    }

    match /rateLimits/{emailHash} {
      allow read: if request.auth != null
                  && request.auth.token.email == resource.data.email;
      allow write: if request.auth != null
                   && request.resource.data.email == request.auth.token.email
                   && request.resource.data.email is string
                   && request.resource.data.attempts is list
                   && request.resource.data.attempts.size() <= 20;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() >= 6
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.body is string
                    && request.resource.data.body.size() >= 10
                    && request.resource.data.image is string
                    && request.resource.data.image.size() > 0
                    && request.resource.data.createdBy is string
                    && request.resource.data.createdBy.size() > 0
                    && request.resource.data.createdBy.size() <= 50
                    && request.resource.data.tagsArray is list
                    && request.resource.data.tagsArray.size() <= 10
                    && request.resource.data.likeCount == 0
                    && request.resource.data.likes == []
                    && request.resource.data.views == 0;
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                      'title', 'body', 'image', 'tagsArray', 'updatedAt'
                    ]);
      allow update: if request.auth == null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']);
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.content is string
                    && request.resource.data.content.size() >= 1
                    && request.resource.data.postId is string
                    && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId));
      allow update: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    match /postViews/{viewId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.postId is string
                    && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId));
      allow update, delete: if false;
    }

    match /savedPosts/{savedId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.postId is string
                    && exists(/databases/$(database)/documents/posts/$(request.resource.data.postId));
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false;
    }
  }
}
